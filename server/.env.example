# DTC checkout server configuration.
# Copy to .env for local dev (npm run dev); on a hosting platform, set these
# as environment variables in its dashboard instead. NEVER commit .env —
# server/.gitignore already excludes it.

# From https://developer.paypal.com -> Apps & Credentials.
# Use the Sandbox app's credentials first; swap to Live only at launch.
# The CLIENT_ID is public (it also goes in docs/assets/js/commerce/
# commerce-config.js). The SECRET is the key to the money — it must exist
# ONLY here and in the host's env settings, nowhere else, and must be
# rotated immediately if it ever leaks.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# "sandbox" or "live". Anything else falls back to sandbox (fails safe).
PAYPAL_ENV=sandbox

# Exact origins allowed to call this API, comma-separated, no trailing
# slashes. For the GitHub Pages site:
#   ALLOWED_ORIGINS=https://2h5.github.io
# Add http://localhost:PORT origins only while developing locally.
ALLOWED_ORIGINS=

# Port to listen on (most hosts inject their own PORT automatically).
PORT=8787

# Set to 1 when running behind a hosting platform's proxy (Render, Railway,
# Fly, Heroku...) so rate limiting sees real client IPs.
TRUST_PROXY=1
