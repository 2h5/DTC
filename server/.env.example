# DTC checkout server configuration.
# Copy this file to .env for local sandbox work only. Never commit .env.

# Fail-closed default. The bundled JSON store is intentionally not permitted
# in live mode; PAYPAL_ENV=live will refuse to start until a production store
# adapter is selected and implemented.
PAYPAL_ENV=disabled
CHECKOUT_CREATE_ENABLED=false

# Required only when PAYPAL_ENV=sandbox.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Strongly recommended in sandbox; required by the future production adapter.
PAYPAL_WEBHOOK_ID=
PAYPAL_EXPECTED_MERCHANT_ID=
PAYPAL_EXPECTED_MERCHANT_EMAIL=

# Exact browser origins, comma-separated, with no paths or trailing slashes.
# Example: https://2h5.github.io,http://localhost:8000
ALLOWED_ORIGINS=

# The bundled store is for disabled/sandbox, single-instance scaffolding only.
# Point this at a persistent, private directory if sandbox state must survive.
ORDER_DATA_DIR=

PORT=8787
TRUST_PROXY=0
PAYPAL_TIMEOUT_MS=8000
PAYPAL_MAX_RETRIES=1
CHECKOUT_RATE_LIMIT=30
WEBHOOK_RATE_LIMIT=120
